<header class="header">
  <nav class="nav">
    <a href="/" class="nav-links">Messages</a>

    <% if (user) { %>
      
      <% if (!user.membership_status) { %>
        <a href="/user/join" class="nav-links">Join</a>
      <% } %>

      <a href="/user/profile" class="nav-links">Profile</a>
      <a href="/user/logout" class="nav-links btn-signup">Logout</a>

    <% } else { %>

      <a href="/user/login" class="nav-links btn-login">Login</a>
      <a href="/user/sign-up" class="nav-links btn-signup">Sign-up</a>

    <% } %>
  </nav>
</header>