<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

<%- include('header') %>

<main class="container">
  <div class="error-container">
    <h1><%= status || 404 %></h1>
    <p><%= message || 'Page not found' %></p>

    <% if (details) { %>
      <p><%= details %></p>
    <% } %>

  </div>
</main>

</body>
</html>